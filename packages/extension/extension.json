{
  "id": "builtin.chat-view-2",
  "name": "Chat 2",
  "workerName": "Chat 2 Worker",
  "description": "A focused, low-overhead coding agent for Lvce Editor",
  "repository": "https://github.com/lvce-editor/chat-view-2",
  "browser": "dist/chatMain.js",
  "isolated": true,
  "categories": ["Other"],
  "configuration": {
    "chat2.backendUrl": {
      "type": "string",
      "default": ""
    },
    "chat2.experimentalFocusMode": {
      "type": "boolean",
      "default": false,
      "description": "Show an experimental control that lets Chat 2 temporarily take over the workbench."
    },
    "chat2.fontFamily": {
      "type": "string",
      "default": "inherit",
      "description": "Font family for chat task list items, for example monospace."
    },
    "chat2.fontSize": {
      "type": "string",
      "default": "13px",
      "description": "Font size for chat task list items, for example 20px."
    },
    "chat2.supportsStreaming": {
      "type": "boolean",
      "default": false,
      "description": "Whether the configured chat backend supports streaming responses."
    }
  },
  "activation": [
    "onView:chat2.views.chat",
    "onCommand:chat2.createSession",
    "onCommand:chat2.runPrompt",
    "onCommand:chat2.sendMessage",
    "onCommand:chat2.show",
    "onCommand:chat2.submit",
    "onCommand:chat2.toggleFocusMode"
  ],
  "commands": [
    {
      "id": "chat2.createSession",
      "label": "Chat 2: Create Headless Session"
    },
    {
      "id": "chat2.runPrompt",
      "label": "Chat 2: Run Headless Prompt"
    },
    {
      "id": "chat2.sendMessage",
      "label": "Chat 2: Send Headless Message"
    },
    {
      "id": "chat2.show",
      "label": "Chat 2: Show"
    },
    {
      "id": "chat2.submit",
      "label": "Chat 2: Submit Message"
    },
    {
      "id": "chat2.toggleFocusMode",
      "label": "Chat 2: Toggle Focus Mode"
    }
  ],
  "views": [
    {
      "css": "chat.css",
      "displayName": "Chat 2",
      "id": "chat2.views.chat",
      "title": "Chat 2",
      "icon": "chat.svg",
      "kind": "virtualDom",
      "showSideBarHeader": false
    }
  ],
  "keybindings": [
    {
      "key": "Enter",
      "command": "chat2.submit",
      "when": "chat2.composerFocus"
    }
  ]
}
